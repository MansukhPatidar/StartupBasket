---
// Server-rendered pagination nav. Anchor tags only — must be crawlable.
// Always includes first and last page links so any idea is reachable in
// at most 2 hops from /ideas/, regardless of how deep the catalog grows.
interface Props {
  currentPage: number;
  lastPage: number;
  // URL builder. Receives a page number, returns an absolute or root-relative
  // path. Page 1 stays at /ideas/ (the canonical surface) — pages 2+ go to
  // /ideas/page/N/.
  hrefForPage: (page: number) => string;
}

const { currentPage, lastPage, hrefForPage } = Astro.props;

// Build the visible window of page numbers. Pattern:
//   1 ... (current-1) current (current+1) ... last
// Always show first and last; collapse interior with ellipses.
function buildPages(current: number, last: number): (number | "…")[] {
  if (last <= 7) {
    return Array.from({ length: last }, (_, i) => i + 1);
  }
  const pages: (number | "…")[] = [1];
  const start = Math.max(2, current - 1);
  const end = Math.min(last - 1, current + 1);
  if (start > 2) pages.push("…");
  for (let p = start; p <= end; p++) pages.push(p);
  if (end < last - 1) pages.push("…");
  pages.push(last);
  return pages;
}

const pages = buildPages(currentPage, lastPage);
const prevHref = currentPage > 1 ? hrefForPage(currentPage - 1) : null;
const nextHref = currentPage < lastPage ? hrefForPage(currentPage + 1) : null;
---

{lastPage > 1 && (
  <nav
    class="mt-10 flex items-center justify-center gap-1 text-sm"
    aria-label="Pagination"
  >
    {prevHref ? (
      <a
        href={prevHref}
        rel="prev"
        class="px-3 py-2 rounded-lg border border-surface-border hover:bg-surface-card text-surface-fg/80 hover:text-surface-fg transition"
      >
        ‹ Previous page
      </a>
    ) : (
      <span
        class="px-3 py-2 rounded-lg border border-surface-border text-muted/50 cursor-not-allowed"
        aria-disabled="true"
      >
        ‹ Previous page
      </span>
    )}

    {pages.map((p) =>
      p === "…" ? (
        <span class="px-2 text-muted" aria-hidden="true">…</span>
      ) : p === currentPage ? (
        <span
          class="px-3 py-2 rounded-lg bg-accent text-white font-semibold tabular-nums"
          aria-current="page"
        >
          {p}
        </span>
      ) : (
        <a
          href={hrefForPage(p)}
          class="px-3 py-2 rounded-lg border border-surface-border hover:bg-surface-card text-surface-fg/80 hover:text-surface-fg transition tabular-nums"
        >
          {p}
        </a>
      ),
    )}

    {nextHref ? (
      <a
        href={nextHref}
        rel="next"
        class="px-3 py-2 rounded-lg border border-surface-border hover:bg-surface-card text-surface-fg/80 hover:text-surface-fg transition"
      >
        Next page ›
      </a>
    ) : (
      <span
        class="px-3 py-2 rounded-lg border border-surface-border text-muted/50 cursor-not-allowed"
        aria-disabled="true"
      >
        Next page ›
      </span>
    )}
  </nav>
)}
