---
import type { Idea } from "../lib/ideas";
import ScoreBadge from "./ScoreBadge.astro";
import VerdictBadge from "./VerdictBadge.astro";
import TagBadge from "./TagBadge.astro";
import Engagement from "./Engagement.tsx";

interface Props {
  idea: Idea;
}

const { idea } = Astro.props;

// Compose all tags into a single ordered list, then cap and overflow.
const allTags: { label: string; kind: "vertical" | "model" | "geography" | "secondary" }[] = [
  { label: idea.data.tags.vertical, kind: "vertical" },
  { label: idea.data.tags.model, kind: "model" },
  { label: idea.data.tags.geography, kind: "geography" },
  ...idea.data.tags.secondary.map((t) => ({ label: t, kind: "secondary" as const })),
];
const MAX_VISIBLE = 3;
const visibleTags = allTags.slice(0, MAX_VISIBLE);
const hiddenCount = Math.max(0, allTags.length - MAX_VISIBLE);

const dateStr = idea.data.date.toISOString().slice(0, 10);
---

<a
  href={`/ideas/${idea.data.slug}`}
  class="card card-hover group p-5 relative overflow-hidden flex flex-col h-full"
  data-search={`${idea.data.title} ${idea.data.oneLiner} ${idea.data.tags.vertical} ${idea.data.tags.model} ${idea.data.tags.geography} ${idea.data.tags.secondary.join(" ")}`}
  data-vertical={idea.data.tags.vertical}
  data-model={idea.data.tags.model}
  data-geography={idea.data.tags.geography}
  data-verdict={idea.data.verdict}
>
  <!-- Hover accent line -->
  <span
    class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"
  ></span>

  <div class="flex items-center gap-2 mb-3">
    <ScoreBadge score={idea.data.score} />
    <VerdictBadge verdict={idea.data.verdict} />
    <time class="ts-badge hidden ml-auto text-[11px] text-surface-fg/50 tabular-nums" datetime={dateStr}>
      {dateStr}
    </time>
  </div>

  <h3
    class="display text-[17px] font-semibold leading-snug group-hover:text-accent-600 dark:group-hover:text-accent-400 transition"
  >
    {idea.data.title}
  </h3>

  <p class="mt-2 text-[13.5px] text-surface-fg/70 leading-relaxed line-clamp-3">
    {idea.data.oneLiner}
  </p>

  <!-- Tags directly under the body, capped with +N overflow. Static (non-link) inside the card
       <a> to avoid nested-anchor reflow. -->
  <div class="mt-3 flex flex-wrap gap-1.5">
    {visibleTags.map((t) => <TagBadge label={t.label} kind={t.kind} static />)}
    {
      hiddenCount > 0 && (
        <span class="pill bg-surface-subtle text-surface-fg/60 ring-surface-border dark:bg-white/5 dark:text-white/60 dark:ring-white/10">
          +{hiddenCount}
        </span>
      )
    }
  </div>

  <!-- Spacer pushes the stats strip to the bottom. -->
  <div class="flex-1"></div>

  <!-- Engagement stats (live via Supabase). -->
  <div class="mt-4 pt-3 border-t border-surface-border/60">
    <Engagement client:visible slug={idea.data.slug} variant="card" />
  </div>
</a>
