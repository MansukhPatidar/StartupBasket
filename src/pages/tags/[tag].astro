---
import BaseLayout from "../../layouts/BaseLayout.astro";
import IdeaCard from "../../components/IdeaCard.astro";
import { getAllIdeas, getAllTags } from "../../lib/ideas";
import { tagSlug } from "../../lib/tags";
import { tagMeta } from "../../lib/seo";

export async function getStaticPaths() {
  const tags = await getAllTags();
  return tags.map((t) => ({
    params: { tag: tagSlug(t.value) },
    props: { tagValue: t.value, count: t.count, kind: t.kind },
  }));
}

const { tagValue, count, kind } = Astro.props;
const ideas = await getAllIdeas();
const matched = ideas.filter((i) => {
  const t = i.data.tags;
  return (
    t.vertical === tagValue ||
    t.model === tagValue ||
    t.geography === tagValue ||
    t.secondary.includes(tagValue)
  );
});

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const meta = tagMeta(tagValue, tagSlug(tagValue), count, siteUrl);
---

<BaseLayout meta={meta}>
  <section class="border-b border-surface-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-12 pb-10">
      <a href="/ideas" class="inline-flex items-center gap-1 text-sm text-surface-fg/60 hover:text-surface-fg transition">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        All ideas
      </a>
      <div class="mt-3 flex items-center gap-2">
        <span class="text-xs uppercase tracking-widest text-muted font-medium">{kind}</span>
        <span class="text-xs text-muted">·</span>
        <span class="text-xs text-muted font-mono tabular-nums">{matched.length} ideas</span>
      </div>
      <h1 class="display mt-2 text-4xl sm:text-5xl font-semibold tracking-tight">
        <span class="text-surface-fg/40">Tagged</span>{" "}
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-accent-600 to-amber-500 dark:from-accent-300 dark:to-amber-400">{tagValue}</span>
      </h1>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <h2 class="sr-only">Ideas tagged {tagValue}</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {matched.map((idea) => <IdeaCard idea={idea} />)}
    </div>
  </section>
</BaseLayout>
