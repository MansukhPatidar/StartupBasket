---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { SeoMeta } from "../lib/seo";

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const meta: SeoMeta = {
  title: "About — StartupBasket",
  description:
    "StartupBasket is a daily catalog of AI product ideas, filtered through a 5-axis feasibility rubric.",
  canonical: `${siteUrl}/about`,
  ogImage: `${siteUrl}/og-default.png`,
  ogType: "website",
};

const axes = [
  { name: "Demand signal strength", weight: 25, desc: "Real evidence people want this today — search traffic, paid competitors, viral threads. No \"I think people would buy this.\"" },
  { name: "Build simplicity", weight: 25, desc: "A small team can ship a credible v1 in 8–12 weeks on off-the-shelf APIs and standard infra." },
  { name: "Distribution feasibility", weight: 20, desc: "A concrete first-100-customers playbook. Named channels, named lists, realistic conversion." },
  { name: "Revenue path clarity", weight: 20, desc: "Pricing benchmarked against incumbents. The math to $1M ARR pencils out without aggressive assumptions." },
  { name: "Moat / defensibility", weight: 10, desc: "A reason this doesn't get cloned in 6 months — data, integrations, regulatory, or sheer execution speed." },
];
---

<BaseLayout meta={meta}>
  <section class="relative overflow-hidden border-b border-surface-border">
    <div class="absolute inset-0 bg-hero-light dark:bg-hero-dark opacity-60" aria-hidden="true"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 pt-16 pb-12">
      <p class="text-xs uppercase tracking-widest text-muted font-medium mb-3">About</p>
      <h1 class="display text-4xl sm:text-5xl font-semibold tracking-tight leading-[1.05]">
        How StartupBasket&nbsp;works.
      </h1>
      <p class="mt-5 text-lg text-surface-fg/75 leading-relaxed">
        One AI product idea, every day, filtered through the same operator persona and
        scored against the same rubric. The goal: surface ideas a small team could
        realistically ship and scale to $1M–$5M ARR.
      </p>
    </div>
  </section>

  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12 prose-idea">
    <h2>The persona</h2>
    <p>
      An experienced tech entrepreneur — fifteen-plus years shipping software, two prior
      exits — looking for the next thing to build. They reject:
    </p>
    <ul>
      <li>Unicorns, billion-dollar TAMs, or "change the world" pitches</li>
      <li>Ideas that need $10M+ before first revenue</li>
      <li>Regulated markets unless the regulation itself is the moat</li>
      <li>Crypto / NFT / web3 revivals</li>
      <li>"Uber for X" without a genuine underlying insight</li>
    </ul>
    <p>They're hunting for:</p>
    <ul>
      <li>Boring, unsexy markets where incumbents have terrible UX</li>
      <li>Workflows where AI collapses a 2-hour task into 2 minutes</li>
      <li>Tools existing professionals will pay for <em>this week</em></li>
      <li>Localized plays — especially India and emerging markets</li>
      <li>Micro-SaaS too small for VCs, perfect for a bootstrapped operator</li>
    </ul>

    <h2>The rubric</h2>
    <p>Five weighted axes, summing to 100. Each idea scored honestly — not aspirationally.</p>
    <table>
      <thead>
        <tr><th>Axis</th><th>Weight</th><th>What it measures</th></tr>
      </thead>
      <tbody>
        {axes.map((a) => (
          <tr>
            <td><strong>{a.name}</strong></td>
            <td class="font-mono tabular-nums">{a.weight}</td>
            <td>{a.desc}</td>
          </tr>
        ))}
      </tbody>
    </table>
    <p>
      Total ≥ <strong>70</strong> = <strong>GO</strong>. 50–69 = <strong>MAYBE</strong>.
      Below 50 = <strong>PASS</strong>. PASSes stay in the catalog as negative examples.
    </p>

    <h2>The catalog</h2>
    <p>
      Every proposal is a self-contained, structured document with tags, search, and
      per-idea SEO. New ideas land regularly, generated by a scheduled agent following the
      same rubric.
    </p>
  </article>
</BaseLayout>
