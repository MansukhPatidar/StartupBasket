---
import BaseLayout from "../layouts/BaseLayout.astro";
import IdeaCard from "../components/IdeaCard.astro";
import HeroIdea from "../components/HeroIdea.astro";
import { getAllIdeas, getAllTags } from "../lib/ideas";
import { tagSlug } from "../lib/tags";
import { homepageMeta } from "../lib/seo";

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const meta = homepageMeta(siteUrl);

const all = await getAllIdeas();

// Hero idea: highest-scored idea from the current week (Mon-Sun).
// Falls back to highest-scored overall if no ideas this week.
const now = new Date();
const monday = new Date(now);
monday.setDate(now.getDate() - ((now.getDay() + 6) % 7));
monday.setHours(0, 0, 0, 0);

const thisWeek = all.filter((i) => i.data.date >= monday);
const heroPool = thisWeek.length > 0 ? thisWeek : all;
const heroIdea = [...heroPool].sort((a, b) => b.data.score - a.data.score)[0];

const recent = all.filter((i) => i.data.slug !== heroIdea.data.slug).slice(0, 6);

const topVerticals = (await getAllTags())
  .filter((t) => t.kind === "vertical")
  .sort((a, b) => b.count - a.count)
  .slice(0, 8);

const stats = {
  total: all.length,
  go: all.filter((i) => i.data.verdict === "GO" || i.data.verdict === "STRONG GO").length,
  validate: all.filter((i) => i.data.verdict === "VALIDATE").length,
  avg: Math.round(all.reduce((s, i) => s + i.data.score, 0) / all.length),
};
---

<BaseLayout meta={meta}>
  <!-- HERO — pitch + featured idea -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-hero-light dark:bg-hero-dark" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-dotgrid opacity-60" aria-hidden="true"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 pt-16 sm:pt-24 pb-14">
      <div class="max-w-3xl mb-12 sm:mb-16">
        <div class="inline-flex items-center gap-2 mb-6 text-xs font-medium text-surface-fg/70">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
          </span>
          New ideas, regularly.
        </div>

        <h1 class="display text-[40px] sm:text-[56px] lg:text-[64px] font-semibold leading-[1.04]">
          AI startup ideas,<br />
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-accent-600 to-amber-500 dark:from-accent-300 dark:to-amber-400">
            scored honestly.
          </span>
        </h1>

        <p class="mt-5 text-[17px] sm:text-[19px] text-surface-fg/70 leading-relaxed max-w-2xl">
          A daily catalog of AI startup and SaaS ideas for bootstrapped founders and
          small teams — each one pressure-tested across seven axes: problem intensity,
          demand evidence, build feasibility, distribution, revenue, time-to-revenue,
          and defensibility.
        </p>

        <div class="mt-7 flex flex-wrap items-center gap-3">
          <a href="/ideas" class="btn btn-primary">
            Browse all ideas
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="/about" class="btn btn-outline">How it works</a>
        </div>
      </div>

      <!-- Featured idea panel -->
      <HeroIdea idea={heroIdea} />
    </div>
  </section>

  <!-- VERTICALS STRIP -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-10 border-t border-surface-border">
    <div class="flex items-center justify-between mb-4 gap-4">
      <p class="text-xs uppercase tracking-widest text-muted font-medium">Browse by vertical</p>
      <a href="/ideas" class="text-xs text-surface-fg/60 hover:text-surface-fg transition">All filters →</a>
    </div>
    <div class="flex flex-wrap gap-2">
      {topVerticals.map((t) => (
        <a
          href={`/tags/${tagSlug(t.value)}`}
          class="inline-flex items-center gap-2 text-sm px-3 py-1.5 rounded-lg border border-surface-border bg-surface-card hover:bg-surface-subtle hover:border-surface-fg/40 transition"
        >
          <span class="font-medium">{t.value}</span>
          <span class="text-xs text-muted font-mono tabular-nums">{t.count}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- RECENT -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="flex items-end justify-between mb-6">
      <div>
        <p class="text-xs uppercase tracking-widest text-muted font-medium mb-1">Latest</p>
        <h2 class="display text-2xl sm:text-3xl font-semibold tracking-tight">Recently added</h2>
      </div>
      <a href="/ideas" class="text-sm text-surface-fg/70 hover:text-surface-fg flex items-center gap-1">
        All ideas
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {recent.map((idea) => <IdeaCard idea={idea} />)}
    </div>
  </section>

  <!-- HOW IT WORKS / RUBRIC TEASER -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-20 border-t border-surface-border">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-xs uppercase tracking-widest text-muted font-medium mb-3">The rubric</p>
        <h2 class="display text-3xl sm:text-4xl font-semibold tracking-tight mb-4">
          Seven axes, weighted to&nbsp;100.
        </h2>
        <p class="text-surface-fg/70 leading-relaxed mb-6">
          Every proposal passes gating criteria, then is scored across seven weighted axes
          with qualitative modifiers and a structured verdict — including kill criteria
          that tell you when to quit.
        </p>
        <a href="/about" class="btn btn-outline">Read the methodology</a>
      </div>
      <ul class="space-y-3">
        {[
          { name: "Problem intensity", weight: 20, desc: "How painful is this? Would they pay today?" },
          { name: "Demand evidence", weight: 15, desc: "Hard signals — spend, competitors, complaints." },
          { name: "Build feasibility", weight: 15, desc: "Can a small team ship v1 in 90 days?" },
          { name: "Distribution clarity", weight: 15, desc: "Concrete path to the first 100 customers." },
          { name: "Revenue mechanics", weight: 15, desc: "Does the math pencil out without heroics?" },
          { name: "Time to revenue", weight: 10, desc: "Weeks to first paying customer." },
          { name: "Defensibility", weight: 10, desc: "What stops a copycat in 6 months?" },
        ].map((axis) => (
          <li class="card p-4 flex items-center justify-between">
            <div>
              <p class="font-semibold display">{axis.name}</p>
              <p class="text-sm text-muted mt-0.5">{axis.desc}</p>
            </div>
            <span class="font-mono text-sm text-surface-fg/60 tabular-nums">+{axis.weight}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
