---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import IdeaCard from "../../../components/IdeaCard.astro";
import FilterSidebar from "../../../components/FilterSidebar.tsx";
import Pagination from "../../../components/Pagination.astro";
import { getAllIdeas, getAllTags } from "../../../lib/ideas";
import type { SeoMeta } from "../../../lib/seo";

export const PAGE_SIZE = 24;

export async function getStaticPaths() {
  const ideas = await getAllIdeas();
  const lastPage = Math.max(1, Math.ceil(ideas.length / PAGE_SIZE));
  // Page 1 lives at /ideas/ (handled by ../index.astro). Skip it here.
  const pages: { params: { page: string }; props: { page: number; lastPage: number } }[] = [];
  for (let p = 2; p <= lastPage; p++) {
    pages.push({ params: { page: String(p) }, props: { page: p, lastPage } });
  }
  return pages;
}

interface PageProps {
  page: number;
  lastPage: number;
}
const { page: currentPage, lastPage } = Astro.props as PageProps;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const allIdeas = await getAllIdeas();
const tags = await getAllTags();

const start = (currentPage - 1) * PAGE_SIZE;
const pageIdeas = allIdeas.slice(start, start + PAGE_SIZE);

const stats = {
  total: allIdeas.length,
  go: allIdeas.filter(
    (i) => i.data.verdict === "GO" || i.data.verdict === "STRONG GO",
  ).length,
  validate: allIdeas.filter((i) => i.data.verdict === "VALIDATE").length,
  pass: allIdeas.filter((i) => i.data.verdict === "PASS").length,
  avg: Math.round(
    allIdeas.reduce((s, i) => s + i.data.score, 0) / allIdeas.length,
  ),
};

const hrefForPage = (p: number) =>
  p === 1 ? `${siteUrl}/ideas/` : `${siteUrl}/ideas/page/${p}/`;

// Self-canonical per page (NOT pointed at page 1) — Google treats paginated
// pages as independent. A canonical to page 1 would de-index the cards on
// pages 2+.
const meta: SeoMeta = {
  title: `All ideas — Page ${currentPage} — StartupBasket`,
  description: `Browse all ${allIdeas.length} AI product ideas (page ${currentPage} of ${lastPage}), filterable by vertical, business model, geography, and verdict.`,
  canonical: hrefForPage(currentPage),
  ogImage: `${siteUrl}/og-default.png`,
  ogType: "website",
  prev: hrefForPage(currentPage - 1),
  next: currentPage < lastPage ? hrefForPage(currentPage + 1) : undefined,
};
---

<BaseLayout meta={meta}>
  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-surface-border">
    <div class="absolute inset-0 bg-hero-light dark:bg-hero-dark" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-dotgrid opacity-60" aria-hidden="true"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 pt-14 sm:pt-20 pb-14">
      <div class="grid lg:grid-cols-[1fr_auto] gap-8 lg:gap-12 items-end">
        <div>
          <div class="inline-flex items-center gap-2 mb-4 text-xs font-medium text-surface-fg/70">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-accent"></span>
            <span class="uppercase tracking-widest">Explore — page {currentPage} of {lastPage}</span>
          </div>
          <h1 class="display text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.02]">
            Every idea,<br/>
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-accent-600 to-amber-500 dark:from-accent-300 dark:to-amber-400">
              scored and filterable.
            </span>
          </h1>
          <p class="mt-5 text-[17px] text-surface-fg/70 leading-relaxed max-w-xl">
            <span class="lg:hidden">{stats.total} proposals, {stats.go} scored GO. Page {currentPage} of {lastPage}.</span>
            <span class="hidden lg:inline">{stats.total} proposals, {stats.go} scored GO. Page {currentPage} of {lastPage}. Use the sidebar to narrow this page by vertical, model, geography, theme, or verdict.</span>
          </p>
        </div>

        <!-- Hero stat tiles -->
        <dl class="grid grid-cols-4 lg:grid-cols-2 gap-px rounded-2xl overflow-hidden border border-surface-border bg-surface-border lg:min-w-[320px]">
          {[
            { label: "Ideas", value: stats.total, tone: "text-surface-fg" },
            { label: "GO", value: stats.go, tone: "text-emerald-600 dark:text-emerald-400" },
            { label: "VALIDATE", value: stats.validate, tone: "text-amber-600 dark:text-amber-400" },
            { label: "Avg", value: stats.avg, tone: "text-surface-fg" },
          ].map((s) => (
            <div class="bg-surface-card p-4">
              <dt class="text-[10px] uppercase tracking-widest text-muted font-medium">{s.label}</dt>
              <dd class={`mt-1 text-2xl font-semibold tabular-nums display ${s.tone}`}>{s.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </section>

  <!-- MAIN — sidebar + grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <div class="grid lg:grid-cols-[260px_1fr] gap-8 lg:gap-12">
      <FilterSidebar tags={tags} total={pageIdeas.length} client:load />

      <div>
        <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-4">
          {pageIdeas.map((idea) => <IdeaCard idea={idea} />)}
        </div>

        <Pagination
          currentPage={currentPage}
          lastPage={lastPage}
          hrefForPage={hrefForPage}
        />
      </div>
    </div>
  </section>
</BaseLayout>
