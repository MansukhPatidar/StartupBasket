---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ScoreBadge from "../../components/ScoreBadge.astro";
import VerdictBadge from "../../components/VerdictBadge.astro";
import TagBadge from "../../components/TagBadge.astro";
import IdeaCard from "../../components/IdeaCard.astro";
import Engagement from "../../components/Engagement.tsx";
import { getAllIdeas } from "../../lib/ideas";
import { ideaMeta } from "../../lib/seo";

export async function getStaticPaths() {
  const ideas = await getAllIdeas();
  return ideas.map((idea) => ({
    params: { slug: idea.data.slug },
    props: { idea },
  }));
}

const { idea } = Astro.props;
const allIdeas = await getAllIdeas();
const related = allIdeas
  .filter(
    (i) =>
      i.data.slug !== idea.data.slug &&
      (i.data.tags.vertical === idea.data.tags.vertical ||
        i.data.tags.model === idea.data.tags.model),
  )
  .slice(0, 3);

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const meta = ideaMeta(idea, siteUrl);
const { Content } = await render(idea);
---

<BaseLayout meta={meta}>
  <!-- Header band -->
  <section class="relative overflow-hidden border-b border-surface-border">
    <div class="absolute inset-0 bg-hero-light dark:bg-hero-dark opacity-60" aria-hidden="true"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 pt-10 pb-12">
      <a href="/ideas" class="inline-flex items-center gap-1 text-sm text-surface-fg/60 hover:text-surface-fg transition">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        All ideas
      </a>

      <div class="mt-5 flex flex-wrap items-center gap-2">
        <ScoreBadge score={idea.data.score} size="md" />
        <VerdictBadge verdict={idea.data.verdict} size="md" />
        <span class="pill bg-surface-subtle text-surface-fg/70 ring-surface-border h-7 text-xs">
          {idea.data.complexity} complexity
        </span>
      </div>

      <h1 class="display mt-5 text-3xl sm:text-4xl lg:text-[44px] font-semibold tracking-tight leading-[1.1]">
        {idea.data.title}
      </h1>

      <p class="mt-5 text-lg sm:text-xl text-surface-fg/75 leading-relaxed">
        {idea.data.oneLiner}
      </p>

      <div class="mt-6 flex flex-wrap gap-1.5">
        <TagBadge label={idea.data.tags.vertical} kind="vertical" />
        <TagBadge label={idea.data.tags.model} kind="model" />
        <TagBadge label={idea.data.tags.geography} kind="geography" />
        {idea.data.tags.secondary.map((t) => <TagBadge label={t} kind="secondary" />)}
      </div>

      <div class="mt-6">
        <Engagement client:load slug={idea.data.slug} variant="detail" countView />
      </div>
    </div>
  </section>

  <article class="max-w-3xl mx-auto px-4 sm:px-6 pt-10 pb-16">
    <div class="prose-idea">
      <Content />
    </div>
  </article>

  {
    related.length > 0 && (
      <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12 border-t border-surface-border">
        <p class="text-xs uppercase tracking-widest text-muted font-medium mb-1">Related</p>
        <h2 class="display text-2xl font-semibold tracking-tight mb-6">More in {idea.data.tags.vertical}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {related.map((i) => <IdeaCard idea={i} />)}
        </div>
      </section>
    )
  }
</BaseLayout>
