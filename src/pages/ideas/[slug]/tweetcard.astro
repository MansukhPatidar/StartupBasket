---
import { getAllIdeas } from "../../../lib/ideas";
import "@fontsource-variable/inter";

export async function getStaticPaths() {
  const ideas = await getAllIdeas();
  return ideas.map((idea) => ({
    params: { slug: idea.data.slug },
    props: { idea },
  }));
}

const { idea } = Astro.props;
const d = idea.data;
const ideaUrl = `https://startupbasket.ai/ideas/${d.slug}/`;
const ogImage = `/ideas/og/${d.slug}.png`;

// Hashtag rules mirror the publish-to-x skill: strip non-alphanumerics from
// each tag value, prepend # — always include #StartupIdeas + #StartupBasket
// plus vertical, model, geography, and every secondary tag.
function hashtag(value: string): string {
  return "#" + value.replace(/[^A-Za-z0-9]/g, "");
}
const hashtags = [
  "#StartupIdeas",
  "#StartupBasket",
  hashtag(d.tags.vertical),
  hashtag(d.tags.model),
  hashtag(d.tags.geography),
  ...d.tags.secondary.map(hashtag),
];
const hashtagLine = hashtags.join(" ");
const tweetText = `${d.title}\n${ideaUrl}\n\n${hashtagLine}`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=1200, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{d.title} — tweet card</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root { color-scheme: dark; }
      html, body {
        margin: 0;
        padding: 0;
        background: #0a0c10;
        font-family: "Inter Variable", "Inter", system-ui, sans-serif;
        color: #f5f5f4;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      body {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px;
      }
      .tw-card {
        width: 1200px;
        background: #0f1115;
        padding: 56px 64px;
        display: flex;
        flex-direction: column;
        box-sizing: border-box;
        border-radius: 18px;
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
      }
      .tw-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 28px;
      }
      .tw-logo {
        width: 44px;
        height: 44px;
        background: #f59e0b;
        color: #0f1115;
        font-size: 20px;
        font-weight: 700;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .tw-brand { font-size: 22px; font-weight: 600; }
      .tw-url {
        margin-left: auto;
        font-size: 18px;
        color: #60a5fa;
        text-decoration: none;
      }
      .tw-url:hover { text-decoration: underline; }
      .tw-title {
        font-size: 38px;
        font-weight: 700;
        line-height: 1.2;
        margin-bottom: 28px;
      }
      .tw-score-img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 14px;
        border: 1px solid #2a2f3a;
        background: #0f1115;
      }
      .tw-hashtags {
        margin-top: 24px;
        font-size: 22px;
        color: #60a5fa;
        line-height: 1.5;
        word-break: break-word;
        cursor: pointer;
        user-select: all;
      }
      .tw-toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 24px;
        flex-wrap: wrap;
      }
      .tw-btn {
        background: #1f2937;
        border: 1px solid #374151;
        color: #f5f5f4;
        padding: 10px 16px;
        border-radius: 10px;
        font-size: 14px;
        font-family: inherit;
        cursor: pointer;
        transition: background 120ms;
      }
      .tw-btn:hover { background: #374151; }
      .tw-btn-accent {
        background: #f59e0b;
        color: #0f1115;
        border-color: #f59e0b;
        font-weight: 600;
      }
      .tw-btn-accent:hover { background: #fbbf24; border-color: #fbbf24; }
      .hint {
        position: fixed;
        bottom: 12px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 12px;
        color: #6b7280;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      .tw-toast {
        position: fixed;
        top: 16px;
        left: 50%;
        transform: translateX(-50%);
        background: #10b981;
        color: #0f1115;
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        opacity: 0;
        pointer-events: none;
        transition: opacity 200ms;
      }
      .tw-toast.show { opacity: 1; }
    </style>
  </head>
  <body>
    <div class="tw-card">
      <div class="tw-header">
        <div class="tw-logo">SB</div>
        <div class="tw-brand">StartupBasket</div>
        <a class="tw-url" href={ideaUrl}>{ideaUrl.replace("https://", "")}</a>
      </div>
      <div class="tw-title">{d.title}</div>
      <img class="tw-score-img" src={ogImage} width="1200" height="630" alt={`Evaluation scores for ${d.title}`} />
      <div class="tw-hashtags" id="hashtags" data-text={tweetText}>{hashtagLine}</div>
      <div class="tw-toolbar">
        <button type="button" class="tw-btn tw-btn-accent" id="copy-tweet">Copy tweet text</button>
        <button type="button" class="tw-btn" id="copy-hashtags">Copy hashtags</button>
        <a class="tw-btn" href={ogImage} download={`${d.slug}.png`}>Download PNG</a>
        <a
          class="tw-btn"
          target="_blank"
          rel="noopener"
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(tweetText)}`}
        >Open in X composer</a>
      </div>
    </div>
    <div class="tw-toast" id="toast">Copied</div>
    <div class="hint">Right-click PNG → Copy Image, then paste into X</div>

    <script is:inline define:vars={{ tweetText, hashtagLine }}>
      const toast = document.getElementById("toast");
      function flash(msg) {
        toast.textContent = msg;
        toast.classList.add("show");
        setTimeout(() => toast.classList.remove("show"), 1200);
      }
      async function copy(text, label) {
        try {
          await navigator.clipboard.writeText(text);
          flash(label + " copied");
        } catch (err) {
          flash("Copy failed");
        }
      }
      document.getElementById("copy-tweet")?.addEventListener("click", () => copy(tweetText, "Tweet"));
      document.getElementById("copy-hashtags")?.addEventListener("click", () => copy(hashtagLine, "Hashtags"));
    </script>
  </body>
</html>
