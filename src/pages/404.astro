---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { SeoMeta } from "../lib/seo";

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const meta: SeoMeta = {
  title: "Page not found — StartupBasket",
  description: "This page doesn't exist. Head back to the catalog to find your next idea.",
  canonical: `${siteUrl}/404/`,
  ogImage: `${siteUrl}/og-default.png`,
  ogType: "website",
};
---

<BaseLayout meta={meta}>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-hero-light dark:bg-hero-dark opacity-60" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-dotgrid opacity-40" aria-hidden="true"></div>

    <div class="relative max-w-2xl mx-auto px-4 sm:px-6 pt-24 sm:pt-32 pb-20 text-center">
      <p class="font-mono tabular-nums text-[13px] uppercase tracking-widest text-muted mb-6">Error · 404</p>

      <h1 class="display text-5xl sm:text-7xl font-semibold tracking-tight leading-[1.02]">
        Nothing here.<br/>
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-accent-600 to-amber-500 dark:from-accent-300 dark:to-amber-400">
          Yet.
        </span>
      </h1>

      <p class="mt-6 text-lg text-surface-fg/70 leading-relaxed max-w-lg mx-auto">
        The page you're looking for doesn't exist, moved, or was never published.
        If you followed a link from elsewhere, it might be stale.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/" class="btn btn-primary">
          Back to home
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="/ideas" class="btn btn-outline">Browse all ideas</a>
      </div>
    </div>
  </section>
</BaseLayout>
