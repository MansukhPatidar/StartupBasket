---
import BaseLayout from "../layouts/BaseLayout.astro";
import TrendingGrid from "../components/TrendingGrid.tsx";
import { getAllIdeas } from "../lib/ideas";
import type { SeoMeta } from "../lib/seo";

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const all = await getAllIdeas();

// Pass minimal data to the client component
const ideaData = all.map((i) => ({
  slug: i.data.slug,
  title: i.data.title,
  oneLiner: i.data.oneLiner,
  score: i.data.score,
  verdict: i.data.verdict,
  vertical: i.data.tags.vertical,
  model: i.data.tags.model,
  geography: i.data.tags.geography,
}));

const meta: SeoMeta = {
  title: "Trending Ideas — StartupBasket",
  description: "The most popular startup ideas ranked by community engagement — views and likes.",
  canonical: `${siteUrl}/trending/`,
  ogImage: `${siteUrl}/og-default.png`,
  ogType: "website",
};
---

<BaseLayout meta={meta}>
  <section class="relative overflow-hidden border-b border-surface-border">
    <div class="absolute inset-0 bg-hero-light dark:bg-hero-dark" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-dotgrid opacity-60" aria-hidden="true"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 pt-14 sm:pt-20 pb-14">
      <div class="inline-flex items-center gap-2 mb-4 text-xs font-medium text-surface-fg/70">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-accent"></span>
        <span class="uppercase tracking-widest">Trending</span>
      </div>
      <h1 class="display text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.02]">
        Trending ideas
      </h1>
      <p class="mt-5 text-[17px] text-surface-fg/70 leading-relaxed max-w-xl">
        Ranked by community engagement — views + 10&times; likes.
        The ideas people keep coming back to.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <TrendingGrid client:load ideas={ideaData} />
  </section>
</BaseLayout>
